# ─────────────────────────────────────────────────────────────────────────────
# AttendanceEngine — Environment Variables
# Copy this to .env and fill in values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://attendance:password@localhost:5432/attendance_engine"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="8h"

# ── Ingest ────────────────────────────────────────────────────────────────────
# Shared secret the aggregator server sends in the header
INGEST_SECRET="change-this-shared-secret"
# Directory to watch for dropped xlsx files (alternative to HTTP push)
WATCH_DIR="/var/attendance/incoming"
# Directory to archive processed files
ARCHIVE_DIR="/var/attendance/archive"

# ── Admin ─────────────────────────────────────────────────────────────────────
# Initial admin user (created on first db:seed)
ADMIN_EMAIL="admin@college.edu"
ADMIN_PASSWORD="change-this-password"

# ── Dashboard CORS origin ─────────────────────────────────────────────────────
DASHBOARD_ORIGIN="http://localhost:5173"

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

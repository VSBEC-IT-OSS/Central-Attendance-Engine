{
  "name": "attendance-engine",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted student attendance data pipeline — ingest, normalise, serve",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/dashboard\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:dashboard": "npm run dev -w apps/dashboard",
    "build": "npm run build -w packages/schema && npm run build -w apps/api && npm run build -w apps/dashboard",
    "test": "npm run test -w apps/api",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p apps/api/tsconfig.json && tsc --noEmit -p apps/dashboard/tsconfig.json",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:studio": "npm run db:studio -w apps/api",
    "db:seed": "npm run db:seed -w apps/api"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
